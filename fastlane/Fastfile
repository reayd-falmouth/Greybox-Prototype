platform :ios do
  private_lane :resolve_ios_version do
    project_path = "#{ENV['IOS_BUILD_PATH']}/Unity-iPhone.xcodeproj"
    plist_path = "#{ENV['IOS_BUILD_PATH']}/Info.plist"

    begin
      version = get_version_number(
        xcodeproj: project_path,
        target: "Unity-iPhone"
      )
      UI.message("Resolved iOS version from Xcode target: #{version}")
      return version
    rescue => ex
      UI.important("get_version_number failed in CI-safe resolution: #{ex.message}")
    end

    version = get_info_plist_value(
      path: plist_path,
      key: "CFBundleShortVersionString"
    )
    UI.message("Resolved iOS version from Info.plist fallback: #{version}")

    if version.to_s.strip.empty?
      UI.user_error!("Unable to resolve iOS version from Xcode project or Info.plist")
    end

    version
  end

  desc "Sync codesigning certificates"
  lane :sync_certificates do
    app_store_connect_api_key(
      key_id: ENV["APPSTORE_KEY_ID"],
      issuer_id: ENV["APPSTORE_ISSUER_ID"],
      key_content: ENV["APPSTORE_P8"]
    )

    match(
      type: "appstore",
      readonly: false,
      app_identifier: ENV["IOS_BUNDLE_ID"]
    )
  end

  desc "Deliver a new Release build to the App Store"
  lane :release do
    build
    upload_to_app_store
  end

  desc "Deliver a new Beta build to Apple TestFlight"
  lane :beta do
    update_info_plist(
      xcodeproj: "#{ENV['IOS_BUILD_PATH']}/Unity-iPhone.xcodeproj",
      plist_path: "Info.plist",
      block: proc do |plist|
        plist["ITSAppUsesNonExemptEncryption"] = false
      end
    )
    build
    upload_to_testflight(skip_waiting_for_build_processing: true)
  end

  desc "Create .ipa"
  lane :build do
    setup_ci

    sync_certificates

    ios_version = resolve_ios_version
    latest_build = latest_testflight_build_number(
      app_identifier: ENV["IOS_BUNDLE_ID"],
      version: ios_version,
      initial_build_number: 0
    )
    next_build = latest_build.to_i + 1
    UI.message("Setting iOS CFBundleVersion to #{next_build}")
    increment_build_number(
      xcodeproj: "#{ENV['IOS_BUILD_PATH']}/Unity-iPhone.xcodeproj",
      build_number: next_build.to_s
    )

    update_code_signing_settings(
      use_automatic_signing: true,
      path: "#{ENV['IOS_BUILD_PATH']}/Unity-iPhone.xcodeproj"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: ENV["sigh_#{ENV['IOS_BUNDLE_ID']}_appstore_team-id"],
      code_sign_identity: "iPhone Distribution",
      targets: "Unity-iPhone",
      path: "#{ENV['IOS_BUILD_PATH']}/Unity-iPhone.xcodeproj",
      profile_name: ENV["sigh_#{ENV['IOS_BUNDLE_ID']}_appstore_profile-name"],
      profile_uuid: ENV["sigh_#{ENV['IOS_BUNDLE_ID']}_appstore"]
    )

    build_app(
      project: "#{ENV['IOS_BUILD_PATH']}/Unity-iPhone.xcodeproj",
      scheme: "Unity-iPhone",
      sdk: "iphoneos18.5"
    )
  end
end

platform :android do
  desc "Upload to Production"
  lane :production do
    upload_to_play_store(
      track: "production",
      release_status: "completed",
      aab: "build/Android/Android.aab"
    )
  end

  desc "Upload to Internal"
  lane :internal do
    upload_to_play_store(
      track: "internal",
      # Draft apps only accept draft releases until first publish in Play Console.
      release_status: "draft",
      aab: "build/Android/Android.aab"
    )
  end
end
